# Database connection string
# For Neon.tech: postgresql://user:password@host/database?sslmode=require
# For local: postgresql://user:password@localhost:5432/radarbuds
DATABASE_URL="postgresql://user:password@host/database"

# Supabase Auth (get from Supabase dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Claude API for label scanning (premium feature)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Beverage type (always cannabis for RadarBuds)
NEXT_PUBLIC_BEVERAGE_TYPE="cannabis"
